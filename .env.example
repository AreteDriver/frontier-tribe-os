# Backend
DATABASE_URL=postgresql+asyncpg://tribeuser:tribepass@localhost:5432/tribedb
REDIS_URL=redis://localhost:6379
EVE_FRONTIER_CLIENT_ID=your_client_id
EVE_FRONTIER_CLIENT_SECRET=your_client_secret
EVE_FRONTIER_CALLBACK_URL=http://localhost:5173/auth/callback
SECRET_KEY=change-me-to-a-random-32-char-string-minimum
ENVIRONMENT=development
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Docker Compose
POSTGRES_USER=tribeuser
POSTGRES_PASSWORD=change-me-use-a-strong-password
